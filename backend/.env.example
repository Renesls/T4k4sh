# Local defaults
SERVER_PORT=8080
POSTGRES_DB=t4kash
POSTGRES_USER=t4kash
POSTGRES_PASSWORD=t4kash
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/t4kash
SPRING_DATASOURCE_USERNAME=t4kash
SPRING_DATASOURCE_PASSWORD=t4kash
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_DATASOURCE_MAX_POOL_SIZE=5
SPRING_DATASOURCE_MIN_IDLE=1
SPRING_DATASOURCE_CONNECTION_TIMEOUT=30000
APP_CORS_ALLOWED_ORIGINS=*

# Render + Supabase example
# Render provides PORT automatically.
# Use the Supabase Session Pooler when the hosting only has IPv4 networking:
# SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require
# SPRING_DATASOURCE_USERNAME=postgres.PROJECT_REF
# SPRING_DATASOURCE_PASSWORD=your-supabase-database-password
